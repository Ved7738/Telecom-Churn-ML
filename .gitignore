# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pycache
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Jupyter Notebooks checkpoints ─────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Secrets / Environment variables ───────────────────────
.env
.env.local
secrets.yaml

# ── Logs (auto-generated, no need to track) ───────────────
logs/
*.log

# ── Trained model files (large binary files) ──────────────
# These are generated by running train.py
# Tip: use Git LFS if you want to track them
models/*.pkl
models/*.joblib
models/*.h5

# ── Processed data (re-generated from raw) ────────────────
data/processed/

# ── OS junk files ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor folders ──────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── pytest / coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
